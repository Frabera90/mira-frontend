# Supabase (Project Settings -> API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# IMPORTANTE: qui va SOLO la anon key pubblica.
# Non mettere mai la service_role key in variabili VITE_*: finisce nel browser.
